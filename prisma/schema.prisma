datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

model User {
  id        String   @id @default(uuid())
  level     Float    @default(0.0)
  role      String
  name      String
  email     String?  @unique
  domain    String
  stack     String[]
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}

enum QuestionType {
  mcq
  output
}

model Question {
  id            String       @id @default(uuid())
  domain        String
  skillId       String       @map("skill_id")
  type          QuestionType
  text          String
  options       Json?
  correctAnswer String       @map("correct_answer")
  level         Int

  @@index([skillId])
}
